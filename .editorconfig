root = true

[*]
charset = utf-8-bom
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,cshtml,js,css,json,sql,md}]
charset = utf-8-bom
end_of_line = crlf

[*.cs]
indent_style = space
indent_size = 4

[*.cshtml]
indent_style = space
indent_size = 4

[*.js]
indent_style = space
indent_size = 2

[*.css]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2