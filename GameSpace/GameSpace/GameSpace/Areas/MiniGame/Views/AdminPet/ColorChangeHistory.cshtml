@model GameSpace.Areas.MiniGame.Models.ViewModels.ColorChangeHistoryViewModel
@{
    ViewData["Title"] = "寵物換色/換背景歷史記錄";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@await Html.PartialAsync("_MiniGameAdminTabs")

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">寵物換色/換背景歷史記錄</h1>
    </div>

    <!-- 搜尋表單 -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">篩選條件</h6>
        </div>
        <div class="card-body">
            <form method="get" asp-action="ColorChangeHistory">
                <input type="hidden" name="changeType" value="@Model.ChangeType" />
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>會員 ID</label>
                            <input type="number" name="userId" class="form-control" value="@Model.UserId" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>開始日期</label>
                            <input type="date" name="startDate" class="form-control" value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>結束日期</label>
                            <input type="date" name="endDate" class="form-control" value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>&nbsp;</label>
                            <button type="submit" class="btn btn-primary btn-block">搜尋</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- 結果列表 -->
    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">@(Model.ChangeType == "skin" ? "換膚色" : "換背景")記錄</h6>
            <span class="badge badge-info">共 @Model.TotalCount 筆記錄</span>
        </div>
        <div class="card-body">
            @if (Model.TotalCount > 0)
            {
                <div class="table-responsive">
                    <table class="table table-bordered" width="100%" cellspacing="0">
                        <thead>
                            <tr>
                                <th>記錄ID</th>
                                <th>會員ID</th>
                                <th>會員名稱</th>
                                <th>變更類型</th>
                                <th>變更時間</th>
                                <th>點數變化</th>
                                <th>說明</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var record in Model.Records)
                            {
                                <tr>
                                    <td>@record.LogId</td>
                                    <td>@record.UserId</td>
                                    <td>@record.UserName</td>
                                    <td>@record.ChangeType</td>
                                    <td>@record.ChangeTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td class="@(record.PointsChange < 0 ? "text-danger" : "text-success")">@record.PointsChange</td>
                                    <td>@record.Description</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- 分頁 -->
                @if (Model.TotalCount > Model.PageSize)
                {
                    <nav>
                        <ul class="pagination justify-content-center">
                            @{
                                var totalPages = (int)Math.Ceiling(Model.TotalCount / (double)Model.PageSize);
                                var currentPage = Model.Page;
                            }
                            @if (currentPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="?userId=@Model.UserId&startDate=@Model.StartDate&endDate=@Model.EndDate&changeType=@Model.ChangeType&page=@(currentPage - 1)&pageSize=@Model.PageSize">上一頁</a>
                                </li>
                            }
                            @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" href="?userId=@Model.UserId&startDate=@Model.StartDate&endDate=@Model.EndDate&changeType=@Model.ChangeType&page=@i&pageSize=@Model.PageSize">@i</a>
                                </li>
                            }
                            @if (currentPage < totalPages)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="?userId=@Model.UserId&startDate=@Model.StartDate&endDate=@Model.EndDate&changeType=@Model.ChangeType&page=@(currentPage + 1)&pageSize=@Model.PageSize">下一頁</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="alert alert-info mb-0">
                    查無資料。
                </div>
            }
        </div>
    </div>
</div>
