@model GameSpace.Areas.MiniGame.Models.ViewModels.PetIndividualSettingsViewModel
@{
    ViewData["Title"] = "會員個別寵物設定";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@await Html.PartialAsync("_MiniGameAdminTabs")

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">會員個別寵物設定</h1>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">寵物資料</h6>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>寵物 ID</label>
                        <input type="text" class="form-control" value="@Model.PetId" readonly />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>會員 ID</label>
                        <input type="text" class="form-control" value="@Model.UserId" readonly />
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>會員名稱</label>
                        <input type="text" class="form-control" value="@Model.UserName" readonly />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>寵物名稱</label>
                        <input type="text" class="form-control" name="petName" value="@Model.PetName" />
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>目前膚色</label>
                        <select class="form-control" name="skinColor">
                            @foreach (var option in Model.ColorOptions)
                            {
                                <option value="@option.ColorCode" selected="@(option.ColorCode == Model.CurrentSkinColor)">@option.ColorName</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>目前背景</label>
                        <select class="form-control" name="background">
                            @foreach (var option in Model.BackgroundOptions)
                            {
                                <option value="@option.BackgroundCode" selected="@(option.BackgroundCode == Model.CurrentBackground)">@option.BackgroundName</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <button type="submit" class="btn btn-primary">儲存變更</button>
                    <a href="@Url.Action("QueryPets", "AdminPet")" class="btn btn-secondary">返回列表</a>
                </div>
            </div>
        </div>
    </div>
</div>
