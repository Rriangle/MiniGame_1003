@model GameSpace.Areas.MiniGame.Models.ViewModels.AdminWalletIndexViewModel
@{
    ViewData["Title"] = "錢包管理";
    Layout = "~/Areas/MiniGame/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">錢包管理</h1>
    </div>

    <div class="row">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                交易總數
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalTransactions</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-list-ul fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                累積增加點數
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalEarned</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-arrow-up fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-danger shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">
                                累積扣除點數
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalSpent</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-arrow-down fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                受影響會員數
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalUsers</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-user-friends fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">搜尋與篩選</h6>
        </div>
        <div class="card-body">
            <form method="get" action="@Url.Action("Index", "AdminWallet")">
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="searchTerm">關鍵字</label>
                            <input type="text" class="form-control" id="searchTerm" name="searchTerm" value="@Model.SearchTerm" placeholder="輸入描述關鍵字">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label for="changeType">變更類型</label>
                            <select class="form-control" id="changeType" name="changeType">
                                <option value="">全部</option>
                                @if (Model.ChangeType == "Point")
                                {
                                    <option value="Point" selected>點數</option>
                                }
                                else
                                {
                                    <option value="Point">點數</option>
                                }
                                @if (Model.ChangeType == "Coupon")
                                {
                                    <option value="Coupon" selected>優惠券</option>
                                }
                                else
                                {
                                    <option value="Coupon">優惠券</option>
                                }
                                @if (Model.ChangeType == "EVoucher")
                                {
                                    <option value="EVoucher" selected>電子禮券</option>
                                }
                                else
                                {
                                    <option value="EVoucher">電子禮券</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label for="sortBy">排序</label>
                            <select class="form-control" id="sortBy" name="sortBy">
                                @if (Model.SortBy == "date")
                                {
                                    <option value="date" selected>日期 (最新)</option>
                                }
                                else
                                {
                                    <option value="date">日期 (最新)</option>
                                }
                                @if (Model.SortBy == "amount")
                                {
                                    <option value="amount" selected>點數 (多到少)</option>
                                }
                                else
                                {
                                    <option value="amount">點數 (多到少)</option>
                                }
                                @if (Model.SortBy == "type")
                                {
                                    <option value="type" selected>類型</option>
                                }
                                else
                                {
                                    <option value="type">類型</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <div class="form-group mb-0">
                            <button type="submit" class="btn btn-primary me-2">
                                <i class="fas fa-search"></i> 搜尋
                            </button>
                            <a href="@Url.Action("Index", "AdminWallet")" class="btn btn-secondary">
                                <i class="fas fa-undo"></i> 重置
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">交易紀錄</h6>
            <small class="text-muted">每頁顯示 @Model.PageSize 筆，共 @Model.TotalCount 筆</small>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="walletTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>紀錄ID</th>
                            <th>會員ID</th>
                            <th>交易類型</th>
                            <th>點數</th>
                            <th>交易時間</th>
                            <th>描述</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.UserWallets != null && Model.UserWallets.Count > 0)
                        {
                            foreach (var record in Model.UserWallets)
                            {
                                <tr>
                                    <td>@record.WalletId</td>
                                    <td>@record.UserId</td>
                                    <td>
                                        @if (record.TransactionType == "earn")
                                        {
                                            <span class="badge bg-success">增加</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">扣除</span>
                                        }
                                    </td>
                                    <td>@record.Amount</td>
                                    <td>@record.TransactionDate.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>@record.Description</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted">目前沒有符合的交易紀錄</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav aria-label="錢包分頁">
                    <ul class="pagination justify-content-center">
                        @if (Model.CurrentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", new { page = Model.CurrentPage - 1, searchTerm = Model.SearchTerm, changeType = Model.ChangeType, sortBy = Model.SortBy })">上一頁</a>
                            </li>
                        }

                        @{
                            var startPage = Math.Max(1, Model.CurrentPage - 2);
                            var endPage = Math.Min(Model.TotalPages, Model.CurrentPage + 2);
                        }

                        @for (var i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : string.Empty)">
                                <a class="page-link" href="@Url.Action("Index", new { page = i, searchTerm = Model.SearchTerm, changeType = Model.ChangeType, sortBy = Model.SortBy })">@i</a>
                            </li>
                        }

                        @if (Model.CurrentPage < Model.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", new { page = Model.CurrentPage + 1, searchTerm = Model.SearchTerm, changeType = Model.ChangeType, sortBy = Model.SortBy })">下一頁</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#walletTable').DataTable({
                paging: false,
                searching: false,
                info: false,
                ordering: true,
                order: [[4, 'desc']],
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.10.24/i18n/Chinese-traditional.json'
                }
            });
        });
    </script>
}
